# --- Required in production ---
JWT_SECRET=change-me-to-a-long-random-string
DB_PASSWORD=change-me
DATABASE_URL=postgres://sgrhp:change-me@db:5432/sgrhp

# --- Optional ---
PORT=4000
APP_PORT=4000
NODE_ENV=production
ENFORCE_2FA=true            # mandatory TOTP for administrators
TENANT_ID=t1
RATE_LIMIT_PER_MIN=300      # 0 disables (tests only)
LOGIN_LIMIT=20
TOKEN_TTL=8h
PGSSL=                      # set to "require" for Azure Database for PostgreSQL

# --- Azure Blob Storage (file storage in production) ---
AZURE_STORAGE_ACCOUNT=      # e.g. stsgrhpprod — auth via Managed Identity, no keys
